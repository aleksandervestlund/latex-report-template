\makeatletter
\newcount\ad@currentdepth
\newcount\ad@maxdepth
\newcount\ad@type
\newcommand*{\ad@measure}[1]{%
  \global\advance\ad@currentdepth by 1\relax
  \ifnum\ad@currentdepth > \ad@maxdepth
    \global\ad@maxdepth=\ad@currentdepth
  \fi
  #1%
  \global\advance\ad@currentdepth by -1\relax
}
\DeclareRobustCommand*{\abr}[1]{%
  \begingroup
    \let\abr\ad@measure
    \global\ad@maxdepth=0\relax
    \global\ad@currentdepth=0\relax
    \setbox\z@=\hbox{$#1$}%
  \endgroup
  \ad@type=\ad@maxdepth\relax
  \@tempcnta=\ad@type
  \divide\@tempcnta by 3\relax
  \multiply\@tempcnta by 3\relax
  \advance\ad@type by -\@tempcnta\relax
  \ifcase\ad@type
    \pbr{#1}%
  \or
    \sbr{#1}%
  \or
    \cbr{#1}%
  \fi
}
\makeatother

